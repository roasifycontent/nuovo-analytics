{"name": "nuovo-ai-dashboard", "files": [{"file": "index.html", "data": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>AI Traffic \u2014 Nuovo Luxury</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Syne:wght@400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js\"></script>\n<style>\n:root {\n  --bg: #0a0a0b;\n  --bg2: #111113;\n  --bg3: #17171a;\n  --border: rgba(255,255,255,0.07);\n  --border2: rgba(255,255,255,0.12);\n  --text: #f0efe8;\n  --muted: #7a7975;\n  --dim: #3a3935;\n  --chatgpt: #10b981;\n  --claude: #e8a87c;\n  --perplexity: #818cf8;\n  --copilot: #38bdf8;\n  --gemini: #f472b6;\n  --gold: #d4a843;\n  --red: #f87171;\n}\n* { box-sizing: border-box; margin: 0; padding: 0; }\nhtml { background: var(--bg); color: var(--text); font-family: 'Syne', sans-serif; font-size: 14px; }\nbody { min-height: 100vh; }\n\n/* SETUP SCREEN */\n#setup {\n  display: flex; align-items: center; justify-content: center;\n  min-height: 100vh; padding: 2rem;\n}\n.setup-card {\n  max-width: 560px; width: 100%;\n  background: var(--bg2); border: 0.5px solid var(--border2);\n  border-radius: 16px; padding: 2.5rem;\n}\n.setup-logo { font-size: 11px; letter-spacing: 0.2em; color: var(--muted); text-transform: uppercase; margin-bottom: 2rem; }\n.setup-logo span { color: var(--gold); }\n.setup-card h1 { font-size: 22px; font-weight: 700; margin-bottom: 8px; }\n.setup-card p { color: var(--muted); font-size: 13px; line-height: 1.6; margin-bottom: 2rem; }\n.field { margin-bottom: 1.25rem; }\n.field label { display: block; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }\n.field input, .field textarea {\n  width: 100%; background: var(--bg3); border: 0.5px solid var(--border2);\n  border-radius: 8px; padding: 10px 14px; color: var(--text); font-family: 'DM Mono', monospace;\n  font-size: 13px; outline: none; transition: border-color 0.2s;\n}\n.field input:focus, .field textarea:focus { border-color: var(--gold); }\n.field textarea { resize: vertical; min-height: 120px; }\n.setup-help { font-size: 11px; color: var(--muted); margin-top: 6px; line-height: 1.5; }\n.setup-help a { color: var(--gold); text-decoration: none; }\n.btn-go {\n  width: 100%; padding: 13px; background: var(--gold); color: #0a0a0b;\n  border: none; border-radius: 8px; font-family: 'Syne', sans-serif;\n  font-size: 13px; font-weight: 700; letter-spacing: 0.05em; cursor: pointer;\n  margin-top: 0.5rem; transition: opacity 0.2s;\n}\n.btn-go:hover { opacity: 0.85; }\n.error-msg { color: var(--red); font-size: 12px; margin-top: 12px; display: none; font-family: 'DM Mono', monospace; }\n\n/* DASHBOARD */\n#dashboard { display: none; }\n.topbar {\n  display: flex; align-items: center; justify-content: space-between;\n  padding: 16px 28px; border-bottom: 0.5px solid var(--border);\n  position: sticky; top: 0; background: var(--bg); z-index: 10;\n}\n.topbar-left { display: flex; align-items: center; gap: 20px; }\n.logo { font-size: 11px; letter-spacing: 0.2em; color: var(--muted); text-transform: uppercase; }\n.logo span { color: var(--gold); }\n.live-dot {\n  display: flex; align-items: center; gap: 6px;\n  font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace;\n}\n.dot-pulse {\n  width: 6px; height: 6px; border-radius: 50%; background: var(--chatgpt);\n  animation: pulse 2s infinite;\n}\n@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }\n.topbar-right { display: flex; align-items: center; gap: 12px; }\n.date-range {\n  font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted);\n  background: var(--bg2); border: 0.5px solid var(--border); border-radius: 6px; padding: 5px 10px;\n}\n.date-range select {\n  background: transparent; border: none; color: var(--muted);\n  font-family: 'DM Mono', monospace; font-size: 11px; outline: none; cursor: pointer;\n}\n.btn-refresh {\n  background: var(--bg2); border: 0.5px solid var(--border2);\n  border-radius: 6px; padding: 5px 12px; color: var(--text); font-family: 'Syne', sans-serif;\n  font-size: 11px; cursor: pointer; letter-spacing: 0.05em; transition: border-color 0.2s;\n}\n.btn-refresh:hover { border-color: var(--gold); }\n.btn-settings {\n  background: transparent; border: 0.5px solid var(--border); border-radius: 6px;\n  padding: 5px 10px; color: var(--muted); font-size: 11px; cursor: pointer; transition: color 0.2s;\n}\n.btn-settings:hover { color: var(--text); }\n\n.main { padding: 28px; max-width: 1400px; margin: 0 auto; }\n\n/* HERO STATS */\n.hero-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }\n.stat-card {\n  background: var(--bg2); border: 0.5px solid var(--border);\n  border-radius: 12px; padding: 20px 22px; position: relative; overflow: hidden;\n  transition: border-color 0.2s;\n}\n.stat-card:hover { border-color: var(--border2); }\n.stat-card::before {\n  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;\n  opacity: 0.6;\n}\n.stat-card.chatgpt::before { background: var(--chatgpt); }\n.stat-card.claude::before { background: var(--claude); }\n.stat-card.perplexity::before { background: var(--perplexity); }\n.stat-card.copilot::before { background: var(--copilot); }\n.stat-label {\n  font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;\n  color: var(--muted); margin-bottom: 12px; display: flex; align-items: center; gap: 7px;\n}\n.src-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }\n.stat-num { font-size: 32px; font-weight: 700; line-height: 1; margin-bottom: 6px; font-family: 'DM Mono', monospace; }\n.stat-sub { font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; }\n.stat-delta {\n  font-size: 11px; font-family: 'DM Mono', monospace; margin-top: 4px;\n  display: flex; align-items: center; gap: 4px;\n}\n.delta-up { color: var(--chatgpt); }\n.delta-down { color: var(--red); }\n\n/* SUMMARY ROW */\n.summary-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }\n.sum-card {\n  background: var(--bg3); border-radius: 8px; padding: 14px 18px;\n  border: 0.5px solid var(--border);\n}\n.sum-label { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }\n.sum-val { font-size: 20px; font-weight: 600; font-family: 'DM Mono', monospace; }\n.sum-val.gold { color: var(--gold); }\n\n/* CHARTS ROW */\n.charts-row { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; margin-bottom: 20px; }\n.chart-card {\n  background: var(--bg2); border: 0.5px solid var(--border);\n  border-radius: 12px; padding: 22px 24px;\n}\n.chart-hdr { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }\n.chart-title { font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }\n.chart-wrap { position: relative; height: 200px; }\n\n/* SOURCES TABLE */\n.sources-card {\n  background: var(--bg2); border: 0.5px solid var(--border);\n  border-radius: 12px; padding: 22px 24px; margin-bottom: 20px;\n}\n.sources-hdr { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }\n.sources-title { font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }\n.src-row {\n  display: grid; grid-template-columns: 140px 1fr 90px 90px 90px 90px;\n  align-items: center; gap: 12px; padding: 10px 0;\n  border-bottom: 0.5px solid var(--border);\n}\n.src-row:last-child { border-bottom: none; }\n.src-row-hdr { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--dim); }\n.src-name { display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 600; }\n.src-name .badge { font-size: 9px; padding: 2px 6px; border-radius: 4px; letter-spacing: 0.05em; }\n.badge-top { background: rgba(212,168,67,0.15); color: var(--gold); }\n.bar-track { background: var(--bg3); border-radius: 20px; height: 4px; overflow: hidden; }\n.bar-fill { height: 4px; border-radius: 20px; transition: width 1s cubic-bezier(.4,0,.2,1); }\n.src-stat { font-family: 'DM Mono', monospace; font-size: 13px; text-align: right; }\n.src-stat.rev { color: var(--gold); }\n.src-stat.eng { color: var(--muted); }\n\n/* BOTTOM ROW */\n.bottom-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }\n.bottom-card {\n  background: var(--bg2); border: 0.5px solid var(--border);\n  border-radius: 12px; padding: 22px 24px;\n}\n.bottom-title { font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 16px; }\n\n.page-row { display: grid; grid-template-columns: 1fr 60px 60px; gap: 8px; padding: 8px 0; border-bottom: 0.5px solid var(--border); font-size: 12px; align-items: center; }\n.page-row:last-child { border-bottom: none; }\n.page-path { font-family: 'DM Mono', monospace; color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n.page-num { text-align: right; font-family: 'DM Mono', monospace; }\n\n.loading-state {\n  display: flex; align-items: center; justify-content: center;\n  height: 100px; color: var(--muted); font-size: 12px; font-family: 'DM Mono', monospace;\n  gap: 8px;\n}\n.spin {\n  width: 14px; height: 14px; border: 1.5px solid var(--dim);\n  border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite;\n}\n@keyframes spin { to { transform: rotate(360deg); } }\n\n/* FOOTER */\n.footer {\n  border-top: 0.5px solid var(--border); padding: 16px 28px;\n  display: flex; align-items: center; justify-content: space-between;\n}\n.footer-left { font-size: 11px; color: var(--dim); font-family: 'DM Mono', monospace; }\n.footer-right { display: flex; gap: 16px; align-items: center; }\n.legend-item { display: flex; align-items: center; gap: 5px; font-size: 10px; color: var(--muted); letter-spacing: 0.05em; text-transform: uppercase; }\n.legend-dot { width: 8px; height: 8px; border-radius: 50%; }\n\n@media (max-width: 900px) {\n  .hero-stats { grid-template-columns: repeat(2, 1fr); }\n  .summary-row { grid-template-columns: repeat(2, 1fr); }\n  .charts-row { grid-template-columns: 1fr; }\n  .src-row { grid-template-columns: 120px 1fr 70px 70px; }\n  .src-row > *:nth-child(5), .src-row > *:nth-child(6) { display: none; }\n  .bottom-row { grid-template-columns: 1fr; }\n}\n</style>\n</head>\n<body>\n\n<!-- SETUP SCREEN -->\n<div id=\"setup\">\n  <div class=\"setup-card\">\n    <div class=\"setup-logo\">Nuovo Luxury <span>/ AI Traffic</span></div>\n    <h1>Connect your GA4</h1>\n    <p>Enter your GA4 property ID and a Google service account key to connect your live data. This is stored locally in your browser \u2014 never sent anywhere except Google's API.</p>\n\n    <div class=\"field\">\n      <label>GA4 Property ID</label>\n      <input type=\"text\" id=\"prop-id\" placeholder=\"123456789\" autocomplete=\"off\">\n      <div class=\"setup-help\">Find this in GA4 \u2192 Admin \u2192 Property Settings. It's the number under \"Property ID\".</div>\n    </div>\n\n    <div class=\"field\">\n      <label>Service Account Private Key (JSON)</label>\n      <textarea id=\"svc-key\" placeholder='{\"type\":\"service_account\",\"project_id\":\"...\",\"private_key\":\"-----BEGIN PRIVATE KEY-----\\n...\",\"client_email\":\"...@...iam.gserviceaccount.com\",...}'></textarea>\n      <div class=\"setup-help\">\n        <a href=\"https://console.cloud.google.com/apis/credentials\" target=\"_blank\">Create a service account</a> in Google Cloud Console \u2192 enable Google Analytics Data API \u2192 download JSON key \u2192 paste here.<br><br>\n        Then in GA4 Admin \u2192 Property Access Management \u2192 add the service account email as <strong>Viewer</strong>.\n      </div>\n    </div>\n\n    <button class=\"btn-go\" onclick=\"connect()\">Connect & Launch Dashboard \u2192</button>\n    <div class=\"error-msg\" id=\"err-msg\"></div>\n\n    <div style=\"margin-top:2rem;padding-top:1.5rem;border-top:0.5px solid var(--border)\">\n      <div style=\"font-size:11px;color:var(--dim);font-family:'DM Mono',monospace;\">Or: <span onclick=\"loadDemo()\" style=\"color:var(--gold);cursor:pointer;text-decoration:underline\">load demo with your known numbers</span></div>\n    </div>\n  </div>\n</div>\n\n<!-- DASHBOARD -->\n<div id=\"dashboard\">\n  <div class=\"topbar\">\n    <div class=\"topbar-left\">\n      <div class=\"logo\">Nuovo Luxury <span>/ AI Traffic</span></div>\n      <div class=\"live-dot\"><span class=\"dot-pulse\"></span> <span id=\"last-fetch\">Live</span></div>\n    </div>\n    <div class=\"topbar-right\">\n      <div class=\"date-range\">\n        <select id=\"date-range-sel\" onchange=\"refreshData()\">\n          <option value=\"7\">Last 7 days</option>\n          <option value=\"28\">Last 28 days</option>\n          <option value=\"90\" selected>Last 90 days</option>\n          <option value=\"180\">Last 180 days</option>\n        </select>\n      </div>\n      <button class=\"btn-refresh\" onclick=\"refreshData()\">\u21bb Refresh</button>\n      <button class=\"btn-settings\" onclick=\"showSetup()\">\u2699 Settings</button>\n    </div>\n  </div>\n\n  <div class=\"main\">\n\n    <!-- HERO STATS -->\n    <div class=\"hero-stats\">\n      <div class=\"stat-card chatgpt\">\n        <div class=\"stat-label\"><span class=\"src-dot\" style=\"background:var(--chatgpt)\"></span>ChatGPT</div>\n        <div class=\"stat-num\" id=\"h-chatgpt\">\u2014</div>\n        <div class=\"stat-sub\">sessions</div>\n        <div class=\"stat-delta\" id=\"hd-chatgpt\"></div>\n      </div>\n      <div class=\"stat-card claude\">\n        <div class=\"stat-label\"><span class=\"src-dot\" style=\"background:var(--claude)\"></span>Claude</div>\n        <div class=\"stat-num\" id=\"h-claude\">\u2014</div>\n        <div class=\"stat-sub\">sessions</div>\n        <div class=\"stat-delta\" id=\"hd-claude\"></div>\n      </div>\n      <div class=\"stat-card perplexity\">\n        <div class=\"stat-label\"><span class=\"src-dot\" style=\"background:var(--perplexity)\"></span>Perplexity</div>\n        <div class=\"stat-num\" id=\"h-perplexity\">\u2014</div>\n        <div class=\"stat-sub\">sessions</div>\n        <div class=\"stat-delta\" id=\"hd-perplexity\"></div>\n      </div>\n      <div class=\"stat-card copilot\">\n        <div class=\"stat-label\"><span class=\"src-dot\" style=\"background:var(--copilot)\"></span>Copilot</div>\n        <div class=\"stat-num\" id=\"h-copilot\">\u2014</div>\n        <div class=\"stat-sub\">sessions</div>\n        <div class=\"stat-delta\" id=\"hd-copilot\"></div>\n      </div>\n    </div>\n\n    <!-- SUMMARY ROW -->\n    <div class=\"summary-row\">\n      <div class=\"sum-card\">\n        <div class=\"sum-label\">Total AI Sessions</div>\n        <div class=\"sum-val\" id=\"s-total\">\u2014</div>\n      </div>\n      <div class=\"sum-card\">\n        <div class=\"sum-label\">Revenue (tracked)</div>\n        <div class=\"sum-val gold\" id=\"s-rev\">\u2014</div>\n      </div>\n      <div class=\"sum-card\">\n        <div class=\"sum-label\">Avg Engagement Rate</div>\n        <div class=\"sum-val\" id=\"s-eng\">\u2014</div>\n      </div>\n      <div class=\"sum-card\">\n        <div class=\"sum-label\">Key Event Rate</div>\n        <div class=\"sum-val\" id=\"s-conv\">\u2014</div>\n      </div>\n    </div>\n\n    <!-- CHARTS -->\n    <div class=\"charts-row\">\n      <div class=\"chart-card\">\n        <div class=\"chart-hdr\">\n          <span class=\"chart-title\">Daily sessions by AI source</span>\n        </div>\n        <div class=\"chart-wrap\">\n          <canvas id=\"trend-chart\"></canvas>\n        </div>\n      </div>\n      <div class=\"chart-card\">\n        <div class=\"chart-hdr\">\n          <span class=\"chart-title\">Source split</span>\n        </div>\n        <div class=\"chart-wrap\">\n          <canvas id=\"pie-chart\"></canvas>\n        </div>\n      </div>\n    </div>\n\n    <!-- SOURCES TABLE -->\n    <div class=\"sources-card\">\n      <div class=\"sources-hdr\">\n        <span class=\"sources-title\">AI sources breakdown</span>\n      </div>\n      <div class=\"src-row src-row-hdr\">\n        <span>Source</span><span>Share</span><span>Sessions</span><span>Revenue</span><span>Eng. rate</span><span>Key events</span>\n      </div>\n      <div id=\"sources-table\"><div class=\"loading-state\"><span class=\"spin\"></span> Fetching data...</div></div>\n    </div>\n\n    <!-- BOTTOM ROW -->\n    <div class=\"bottom-row\">\n      <div class=\"bottom-card\">\n        <div class=\"bottom-title\">Top landing pages from AI</div>\n        <div id=\"pages-table\"><div class=\"loading-state\"><span class=\"spin\"></span></div></div>\n      </div>\n      <div class=\"bottom-card\">\n        <div class=\"bottom-title\">Weekly trend \u2014 total AI sessions</div>\n        <div class=\"chart-wrap\" style=\"height:160px\">\n          <canvas id=\"weekly-chart\"></canvas>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n  <div class=\"footer\">\n    <div class=\"footer-left\" id=\"footer-ts\">\u2014</div>\n    <div class=\"footer-right\">\n      <div class=\"legend-item\"><span class=\"legend-dot\" style=\"background:var(--chatgpt)\"></span>ChatGPT</div>\n      <div class=\"legend-item\"><span class=\"legend-dot\" style=\"background:var(--claude)\"></span>Claude</div>\n      <div class=\"legend-item\"><span class=\"legend-dot\" style=\"background:var(--perplexity)\"></span>Perplexity</div>\n      <div class=\"legend-item\"><span class=\"legend-dot\" style=\"background:var(--copilot)\"></span>Copilot</div>\n    </div>\n  </div>\n</div>\n\n<script>\nconst SOURCES = {\n  chatgpt:    { label: 'ChatGPT',    color: '#10b981', terms: ['chatgpt'] },\n  claude:     { label: 'Claude',     color: '#e8a87c', terms: ['claude'] },\n  perplexity: { label: 'Perplexity', color: '#818cf8', terms: ['perplexity'] },\n  copilot:    { label: 'Copilot',    color: '#38bdf8', terms: ['copilot'] },\n  gemini:     { label: 'Gemini',     color: '#f472b6', terms: ['gemini', 'bard'] }\n};\n\nlet config = {};\nlet charts = {};\nlet refreshTimer;\n\nfunction showError(msg) {\n  const el = document.getElementById('err-msg');\n  el.textContent = msg;\n  el.style.display = 'block';\n}\n\nasync function connect() {\n  const propId = document.getElementById('prop-id').value.trim();\n  const keyJson = document.getElementById('svc-key').value.trim();\n  if (!propId) { showError('Please enter your GA4 Property ID'); return; }\n  if (!keyJson) { showError('Please paste your service account JSON key'); return; }\n\n  let key;\n  try { key = JSON.parse(keyJson); } catch(e) { showError('Invalid JSON \u2014 check the format of your key file'); return; }\n  if (!key.private_key || !key.client_email) { showError('Key file must contain private_key and client_email'); return; }\n\n  config = { propId, key };\n  localStorage.setItem('nuovo_ga4_config', JSON.stringify({ propId, keyStr: keyJson }));\n\n  document.getElementById('setup').style.display = 'none';\n  document.getElementById('dashboard').style.display = 'block';\n  await refreshData();\n  refreshTimer = setInterval(refreshData, 30 * 60 * 1000);\n}\n\nfunction showSetup() {\n  clearInterval(refreshTimer);\n  document.getElementById('setup').style.display = 'flex';\n  document.getElementById('dashboard').style.display = 'none';\n}\n\nasync function getAccessToken() {\n  const key = config.key;\n  const now = Math.floor(Date.now() / 1000);\n  const header = btoa(JSON.stringify({ alg: 'RS256', typ: 'JWT' })).replace(/=/g,'').replace(/\\+/g,'-').replace(/\\//g,'_');\n  const payload = btoa(JSON.stringify({\n    iss: key.client_email,\n    scope: 'https://www.googleapis.com/auth/analytics.readonly',\n    aud: 'https://oauth2.googleapis.com/token',\n    exp: now + 3600, iat: now\n  })).replace(/=/g,'').replace(/\\+/g,'-').replace(/\\//g,'_');\n\n  const toSign = header + '.' + payload;\n  const pemKey = key.private_key.replace(/\\\\n/g, '\\n');\n  const binaryDer = pemToBinary(pemKey);\n  const cryptoKey = await crypto.subtle.importKey('pkcs8', binaryDer, { name: 'RSASSA-PKCS1-v1_5', hash: 'SHA-256' }, false, ['sign']);\n  const sig = await crypto.subtle.sign('RSASSA-PKCS1-v1_5', cryptoKey, new TextEncoder().encode(toSign));\n  const sigB64 = btoa(String.fromCharCode(...new Uint8Array(sig))).replace(/=/g,'').replace(/\\+/g,'-').replace(/\\//g,'_');\n  const jwt = toSign + '.' + sigB64;\n\n  const resp = await fetch('https://oauth2.googleapis.com/token', {\n    method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },\n    body: `grant_type=urn%3Aietf%3Aparams%3Aoauth%3Agrant-type%3Ajwt-bearer&assertion=${jwt}`\n  });\n  const data = await resp.json();\n  if (!data.access_token) throw new Error(data.error_description || 'Auth failed');\n  return data.access_token;\n}\n\nfunction pemToBinary(pem) {\n  const lines = pem.split('\\n').filter(l => !l.startsWith('-----'));\n  const b64 = lines.join('');\n  const bin = atob(b64);\n  const bytes = new Uint8Array(bin.length);\n  for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);\n  return bytes.buffer;\n}\n\nasync function runReport(token, body) {\n  const url = `https://analyticsdata.googleapis.com/v1beta/properties/${config.propId}:runReport`;\n  const resp = await fetch(url, {\n    method: 'POST', headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },\n    body: JSON.stringify(body)\n  });\n  if (!resp.ok) { const e = await resp.json(); throw new Error(e.error?.message || 'API error'); }\n  return resp.json();\n}\n\nfunction getDays() { return parseInt(document.getElementById('date-range-sel').value) || 90; }\n\nasync function refreshData() {\n  document.getElementById('last-fetch').textContent = 'Fetching...';\n  try {\n    let token;\n    if (config.key) {\n      token = await getAccessToken();\n    } else { loadDemoData(); return; }\n\n    const days = getDays();\n    const dateRange = [{ startDate: `${days}daysAgo`, endDate: 'today' }];\n    const aiRegex = Object.values(SOURCES).flatMap(s => s.terms).join('|');\n\n    const [bySource, byDate, byPage] = await Promise.all([\n      runReport(token, {\n        dateRanges: dateRange,\n        dimensions: [{ name: 'sessionSource' }],\n        metrics: [\n          { name: 'sessions' }, { name: 'engagedSessions' },\n          { name: 'totalRevenue' }, { name: 'keyEvents' }\n        ],\n        dimensionFilter: {\n          filter: { fieldName: 'sessionSource', stringFilter: { matchType: 'PARTIAL_REGEXP', value: aiRegex } }\n        }\n      }),\n      runReport(token, {\n        dateRanges: dateRange,\n        dimensions: [{ name: 'date' }, { name: 'sessionSource' }],\n        metrics: [{ name: 'sessions' }],\n        dimensionFilter: {\n          filter: { fieldName: 'sessionSource', stringFilter: { matchType: 'PARTIAL_REGEXP', value: aiRegex } }\n        },\n        orderBys: [{ dimension: { dimensionName: 'date' } }]\n      }),\n      runReport(token, {\n        dateRanges: dateRange,\n        dimensions: [{ name: 'landingPagePlusQueryString' }],\n        metrics: [{ name: 'sessions' }, { name: 'engagementRate' }],\n        dimensionFilter: {\n          filter: { fieldName: 'sessionSource', stringFilter: { matchType: 'PARTIAL_REGEXP', value: aiRegex } }\n        },\n        orderBys: [{ metric: { metricName: 'sessions' }, desc: true }],\n        limit: 10\n      })\n    ]);\n\n    renderData(bySource, byDate, byPage);\n    document.getElementById('last-fetch').textContent = 'Updated ' + new Date().toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });\n    document.getElementById('footer-ts').textContent = 'Last refresh: ' + new Date().toLocaleString('en-GB') + ' \u00b7 GA4 Property ' + config.propId;\n  } catch(err) {\n    document.getElementById('last-fetch').textContent = 'Error: ' + err.message;\n    console.error(err);\n  }\n}\n\nfunction categorise(source) {\n  source = (source || '').toLowerCase();\n  for (const [key, val] of Object.entries(SOURCES)) {\n    if (val.terms.some(t => source.includes(t))) return key;\n  }\n  return 'other';\n}\n\nfunction renderData(bySource, byDate, byPage) {\n  const totals = {};\n  for (const k of Object.keys(SOURCES)) totals[k] = { sessions: 0, engaged: 0, revenue: 0, keyEvents: 0 };\n\n  (bySource.rows || []).forEach(row => {\n    const cat = categorise(row.dimensionValues[0].value);\n    if (!totals[cat]) return;\n    totals[cat].sessions += parseInt(row.metricValues[0].value || 0);\n    totals[cat].engaged  += parseInt(row.metricValues[1].value || 0);\n    totals[cat].revenue  += parseFloat(row.metricValues[2].value || 0);\n    totals[cat].keyEvents+= parseInt(row.metricValues[3].value || 0);\n  });\n\n  const totalSess = Object.values(totals).reduce((a,b) => a + b.sessions, 0);\n  const totalRev  = Object.values(totals).reduce((a,b) => a + b.revenue, 0);\n  const totalEng  = Object.values(totals).reduce((a,b) => a + b.engaged, 0);\n  const totalKE   = Object.values(totals).reduce((a,b) => a + b.keyEvents, 0);\n  const engRate   = totalSess > 0 ? (totalEng / totalSess * 100) : 0;\n  const convRate  = totalSess > 0 ? (totalKE / totalSess * 100) : 0;\n\n  for (const [k, v] of Object.entries(totals)) {\n    const el = document.getElementById('h-' + k);\n    if (el) el.textContent = v.sessions.toLocaleString();\n  }\n\n  document.getElementById('s-total').textContent = totalSess.toLocaleString();\n  document.getElementById('s-rev').textContent = totalRev > 0 ? '\u00a3' + totalRev.toLocaleString('en-GB', { maximumFractionDigits: 0 }) : '\u00a30';\n  document.getElementById('s-eng').textContent = engRate.toFixed(1) + '%';\n  document.getElementById('s-conv').textContent = convRate.toFixed(2) + '%';\n\n  renderSourcesTable(totals, totalSess);\n  renderTrendChart(byDate);\n  renderPieChart(totals);\n  renderPagesTable(byPage);\n  renderWeeklyChart(byDate);\n}\n\nfunction renderSourcesTable(totals, totalSess) {\n  const sorted = Object.entries(totals).filter(([,v]) => v.sessions > 0).sort((a,b) => b[1].sessions - a[1].sessions);\n  const maxS = Math.max(...sorted.map(([,v]) => v.sessions), 1);\n  const el = document.getElementById('sources-table');\n  if (!sorted.length) { el.innerHTML = '<div class=\"loading-state\">No AI referral traffic in this period</div>'; return; }\n  el.innerHTML = sorted.map(([key, v], i) => {\n    const src = SOURCES[key];\n    const pct = totalSess > 0 ? Math.round(v.sessions / totalSess * 100) : 0;\n    const eng = v.sessions > 0 ? (v.engaged / v.sessions * 100).toFixed(1) : '0';\n    return `<div class=\"src-row\">\n      <div class=\"src-name\">\n        <span class=\"src-dot\" style=\"background:${src.color}\"></span>\n        ${src.label}\n        ${i === 0 ? '<span class=\"badge badge-top\">TOP</span>' : ''}\n      </div>\n      <div>\n        <div style=\"display:flex;align-items:center;gap:8px\">\n          <div class=\"bar-track\" style=\"flex:1\"><div class=\"bar-fill\" style=\"width:${Math.round(v.sessions/maxS*100)}%;background:${src.color}\"></div></div>\n          <span style=\"font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);min-width:30px;text-align:right\">${pct}%</span>\n        </div>\n      </div>\n      <span class=\"src-stat\">${v.sessions.toLocaleString()}</span>\n      <span class=\"src-stat rev\">${v.revenue > 0 ? '\u00a3' + v.revenue.toLocaleString('en-GB',{maximumFractionDigits:0}) : '\u2014'}</span>\n      <span class=\"src-stat eng\">${eng}%</span>\n      <span class=\"src-stat\">${v.keyEvents}</span>\n    </div>`;\n  }).join('');\n}\n\nfunction renderTrendChart(byDate) {\n  const dateMap = {};\n  (byDate.rows || []).forEach(row => {\n    const d = row.dimensionValues[0].value;\n    const cat = categorise(row.dimensionValues[1].value);\n    const s = parseInt(row.metricValues[0].value || 0);\n    if (!dateMap[d]) dateMap[d] = {};\n    dateMap[d][cat] = (dateMap[d][cat] || 0) + s;\n  });\n\n  const dates = Object.keys(dateMap).sort();\n  const fmt = d => d.slice(4,6) + '/' + d.slice(6,8);\n  const labels = dates.map(fmt);\n\n  const step = Math.max(1, Math.floor(labels.length / 14));\n  const filteredLabels = labels.map((l, i) => i % step === 0 ? l : '');\n\n  const datasets = Object.entries(SOURCES).map(([key, src]) => ({\n    label: src.label, data: dates.map(d => dateMap[d]?.[key] || 0),\n    borderColor: src.color, backgroundColor: src.color + '20',\n    borderWidth: 1.5, pointRadius: 0, fill: false, tension: 0.3\n  }));\n\n  if (charts.trend) charts.trend.destroy();\n  charts.trend = new Chart(document.getElementById('trend-chart'), {\n    type: 'line', data: { labels: filteredLabels, datasets },\n    options: {\n      responsive: true, maintainAspectRatio: false,\n      plugins: { legend: { display: false } },\n      scales: {\n        x: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#7a7975', font: { family: 'DM Mono', size: 10 }, maxRotation: 0 } },\n        y: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#7a7975', font: { family: 'DM Mono', size: 10 }, precision: 0 } }\n      }\n    }\n  });\n}\n\nfunction renderPieChart(totals) {\n  const entries = Object.entries(totals).filter(([,v]) => v.sessions > 0);\n  if (charts.pie) charts.pie.destroy();\n  charts.pie = new Chart(document.getElementById('pie-chart'), {\n    type: 'doughnut',\n    data: {\n      labels: entries.map(([k]) => SOURCES[k].label),\n      datasets: [{ data: entries.map(([,v]) => v.sessions), backgroundColor: entries.map(([k]) => SOURCES[k].color), borderWidth: 0, hoverOffset: 4 }]\n    },\n    options: {\n      responsive: true, maintainAspectRatio: false, cutout: '70%',\n      plugins: { legend: { position: 'bottom', labels: { color: '#7a7975', font: { family: 'Syne', size: 11 }, boxWidth: 8, boxHeight: 8, padding: 16 } } }\n    }\n  });\n}\n\nfunction renderPagesTable(byPage) {\n  const el = document.getElementById('pages-table');\n  const rows = (byPage.rows || []).slice(0, 8);\n  if (!rows.length) { el.innerHTML = '<div class=\"loading-state\">No data</div>'; return; }\n  el.innerHTML = `<div class=\"page-row\" style=\"opacity:0.5;font-size:10px;letter-spacing:0.1em;text-transform:uppercase\">\n    <span>Page</span><span style=\"text-align:right\">Sessions</span><span style=\"text-align:right\">Eng%</span>\n  </div>` + rows.map(r => {\n    const path = r.dimensionValues[0].value.replace('https://www.nuovoluxury.co.uk','').slice(0,40) || '/';\n    const sess = parseInt(r.metricValues[0].value || 0);\n    const eng  = (parseFloat(r.metricValues[1].value || 0) * 100).toFixed(0);\n    return `<div class=\"page-row\"><span class=\"page-path\">${path}</span><span class=\"page-num\">${sess}</span><span class=\"page-num\" style=\"color:var(--muted)\">${eng}%</span></div>`;\n  }).join('');\n}\n\nfunction renderWeeklyChart(byDate) {\n  const weekMap = {};\n  (byDate.rows || []).forEach(row => {\n    const d = row.dimensionValues[0].value;\n    const year = parseInt(d.slice(0,4)), month = parseInt(d.slice(4,6))-1, day = parseInt(d.slice(6,8));\n    const dt = new Date(year, month, day);\n    const weekStart = new Date(dt); weekStart.setDate(dt.getDate() - dt.getDay());\n    const wk = weekStart.toISOString().slice(0,10);\n    weekMap[wk] = (weekMap[wk] || 0) + parseInt(row.metricValues[0].value || 0);\n  });\n  const weeks = Object.keys(weekMap).sort().slice(-12);\n  const fmt = d => { const [,m,day] = d.split('-'); return `${day}/${m}`; };\n  if (charts.weekly) charts.weekly.destroy();\n  charts.weekly = new Chart(document.getElementById('weekly-chart'), {\n    type: 'bar',\n    data: {\n      labels: weeks.map(fmt),\n      datasets: [{ data: weeks.map(w => weekMap[w]), backgroundColor: '#d4a843', borderRadius: 3 }]\n    },\n    options: {\n      responsive: true, maintainAspectRatio: false,\n      plugins: { legend: { display: false } },\n      scales: {\n        x: { grid: { display: false }, ticks: { color: '#7a7975', font: { family: 'DM Mono', size: 10 }, maxRotation: 0 } },\n        y: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#7a7975', font: { family: 'DM Mono', size: 10 }, precision: 0 } }\n      }\n    }\n  });\n}\n\nfunction loadDemo() {\n  config = { demo: true };\n  document.getElementById('setup').style.display = 'none';\n  document.getElementById('dashboard').style.display = 'block';\n  loadDemoData();\n}\n\nfunction loadDemoData() {\n  const totals = { chatgpt: { sessions: 244, engaged: 124, revenue: 1999, keyEvents: 4 }, claude: { sessions: 2, engaged: 0, revenue: 0, keyEvents: 0 }, perplexity: { sessions: 0, engaged: 0, revenue: 0, keyEvents: 0 }, copilot: { sessions: 0, engaged: 0, revenue: 0, keyEvents: 0 } };\n  const totalSess = 246, totalEng = 124, totalKE = 4;\n  for (const [k, v] of Object.entries(totals)) { const el = document.getElementById('h-'+k); if (el) el.textContent = v.sessions.toLocaleString(); }\n  document.getElementById('s-total').textContent = '246';\n  document.getElementById('s-rev').textContent = '\u00a31,999';\n  document.getElementById('s-eng').textContent = '50.4%';\n  document.getElementById('s-conv').textContent = '1.63%';\n  document.getElementById('last-fetch').textContent = 'Demo mode \u2014 connect GA4 for live data';\n  document.getElementById('footer-ts').textContent = 'Demo data: Feb 11 \u2013 May 11, 2026 \u00b7 Connect GA4 for live data';\n  renderSourcesTable(totals, 246);\n  const demoByDate = { rows: [] };\n  const start = new Date('2026-02-11');\n  for (let i = 0; i < 90; i++) {\n    const d = new Date(start); d.setDate(d.getDate() + i);\n    const ds = d.toISOString().slice(0,10).replace(/-/g,'');\n    const s = Math.floor(Math.random() * 4 + 1);\n    demoByDate.rows.push({ dimensionValues: [{value:ds},{value:'chatgpt.com'}], metricValues: [{value:String(s)}] });\n    if (Math.random() < 0.02) demoByDate.rows.push({ dimensionValues: [{value:ds},{value:'claude.ai'}], metricValues: [{value:'1'}] });\n  }\n  renderTrendChart(demoByDate);\n  renderPieChart(totals);\n  renderWeeklyChart(demoByDate);\n  const demoPages = { rows: [\n    { dimensionValues:[{value:'/products/hybrid-infrared-4-person-2m-sauna'}], metricValues:[{value:'48'},{value:'0.72'}] },\n    { dimensionValues:[{value:'/collections/infrared-saunas'}], metricValues:[{value:'32'},{value:'0.61'}] },\n    { dimensionValues:[{value:'/products/chill-tubs-ice-bath-with-temperature-control-system-built-in'}], metricValues:[{value:'28'},{value:'0.68'}] },\n    { dimensionValues:[{value:'/pages/best-saunas-uk-buyers-guide'}], metricValues:[{value:'21'},{value:'0.75'}] },\n    { dimensionValues:[{value:'/collections/gazebo-and-pergolas-uk'}], metricValues:[{value:'18'},{value:'0.55'}] },\n    { dimensionValues:[{value:'/products/aquark-mr-silence-hot-tub-swim-spa-air-source-inverter-heat-pump'}], metricValues:[{value:'14'},{value:'0.79'}] },\n  ]};\n  renderPagesTable(demoPages);\n}\n\nwindow.addEventListener('load', () => {\n  const saved = localStorage.getItem('nuovo_ga4_config');\n  if (saved) {\n    try {\n      const { propId, keyStr } = JSON.parse(saved);\n      document.getElementById('prop-id').value = propId;\n      document.getElementById('svc-key').value = keyStr;\n    } catch(e) {}\n  }\n});\n</script>\n</body>\n</html>\n"}, {"file": "vercel.json", "data": "{\n  \"version\": 2,\n  \"builds\": [\n    { \"src\": \"index.html\", \"use\": \"@vercel/static\" }\n  ],\n  \"routes\": [\n    { \"src\": \"/(.*)\", \"dest\": \"/index.html\" }\n  ]\n}\n"}], "projectSettings": {"framework": null, "buildCommand": null, "outputDirectory": null, "rootDirectory": null}, "target": "production"}